{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Read",
            "Edit",
            "Write",
            "Bash(just *)",
            "Bash(pkill *)",
            "Bash(kill *)",
            "Bash(lsof *)",
            "Bash(ls *)",
            "Bash(find *)",
            "Bash(cat *)",
            "Bash(head *)",
            "Bash(tail *)",
            "Bash(wc *)",
            "Bash(tree *)",
            "Bash(grep *)",
            "Bash(rg *)",
            "Bash(cargo *)",
            "Bash(pnpm *)",
            "Bash(git *)",
            "Bash(mkdir *)",
            "Bash(cp *)",
            "Bash(mv *)",
            "Bash(rm *)",
            "Bash(echo *)",
            "Bash(trunk *)",
            "WebFetch(domain:*)",
            "WebSearch"
        ],
        "deny": [
            "Bash(curl *)",
            "Bash(wget *)",
            "Bash(curl)",
            "Bash(wget)",
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Read(./**/*.pem)",
            "Read(./**/*.key)"
        ],
        "disableBypassPermissionsMode": "disable"
    }
}